# ──────────────────────────────────────────────────────────────────────────────
# BALGYN — локальная конфигурация.
# Файл .env в .gitignore и НЕ коммитится.
# ──────────────────────────────────────────────────────────────────────────────
# ── Production domain ─────────────────────────────────────────────────────────
# Required for HTTPS (nginx ssl_certificate path + CORS).
DOMAIN=balgyn.kz
# Email used by Let's Encrypt for certificate expiry notifications.
CERTBOT_EMAIL=admin@balgyn.kz

VITE_API_BASE_URL=http://localhost:8080/api/v1
# [ОБЯЗАТЕЛЬНО] Секрет подписи JWT (HS256), минимум 32 байта. Сгенерируйте: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS

# Первый администратор (создаётся при пустой таблице users). Пусто = не создаётся.
BOOTSTRAP_ADMIN_EMAIL=admin@balgyn.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Пароль БД.
POSTGRES_PASSWORD=postgres

# Swagger UI (http://localhost:8080/swagger-ui.html).
SWAGGER_ENABLED=true

# Заполнить каталог тестовыми данными при первом старте (5 групп, 14 коллекций, 16 дизайнов).
# Безопасно: пропускается, если каталог уже наполнен.
APP_SEED_CATALOG=true

# ── MinIO / Storage ──────────────────────────────────────────────────────────
# false = загрузка выключена (локально без MinIO).
STORAGE_ENABLED=false
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_PUBLIC_URL=http://localhost:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET=balgyn-media

# ── CDEK (доставка) ───────────────────────────────────────────────────────────
# Пустые значения = stub/mock-режим. Заполняйте только при интеграции с реальным CDEK.
# CDEK_CLIENT_ID=
# CDEK_CLIENT_SECRET=
# Токен для верификации входящих вебхуков CDEK (X-Authorization header).
# Задаётся в личном кабинете CDEK при регистрации вебхука.
# CDEK_WEBHOOK_TOKEN=

# ── Freedom Pay ───────────────────────────────────────────────────────────────
# Тестовые ключи Freedom Pay. Безопасно хранить в репозитории (sandbox-аккаунт).
# ВАЖНО: для получения callback FreedomPay нужен публичный URL (ngrok / реальный домен).
# Без FREEDOMPAY_RESULT_URL → stub-режим автоматически подтверждает заказы локально.
FREEDOMPAY_MERCHANT_ID=587060
FREEDOMPAY_SECRET_KEY=TOSTcm0z9miUgpyC
FREEDOMPAY_API_URL=https://api.freedompay.kz
# Публичный URL для callback от Freedom Pay. Используйте ngrok для локального тестирования:
# npx ngrok http 8080
# Затем: FREEDOMPAY_RESULT_URL=https://<id>.ngrok.io/api/v1/payments/callback/freedom-pay
FREEDOMPAY_RESULT_URL=
FREEDOMPAY_CALLBACK_SCRIPT_NAME=freedom-pay
FREEDOMPAY_TESTING_MODE=true

# ── PayPal ────────────────────────────────────────────────────────────────────
# Тестовые ключи PayPal Sandbox. Безопасно хранить в репозитории.
# Эти ключи уже вшиты в docker-compose.yml как дефолты — .env не нужен для PayPal.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=AXymWxzrWktAxw9fkuZqBjOEW8MQCKrEWYOOfEQ1bPBKHSfWkH-hfFpeYlYgabr9zIpVT_8N8LWnKtpH
PAYPAL_CLIENT_SECRET=EFPZr6A1Vg2nbFTyr2SuQlxUg0yA4Yj9I-jew4tEa4dkqSQA8fu7AfNZW3-HYmcz-xD5IczuFRTUPBA6
PAYPAL_WEBHOOK_ID=7AS768482S5495201a
