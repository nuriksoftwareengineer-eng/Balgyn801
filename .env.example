# ──────────────────────────────────────────────────────────────────────────────
# BALGYN — локальная конфигурация.
# Файл .env в .gitignore и НЕ коммитится.
# ──────────────────────────────────────────────────────────────────────────────
# ── Production domain ─────────────────────────────────────────────────────────
# Required for HTTPS (nginx ssl_certificate path + CORS).
DOMAIN=balgyn.kz
# Email used by Let's Encrypt for certificate expiry notifications.
CERTBOT_EMAIL=admin@balgyn.kz

VITE_API_BASE_URL=http://localhost:8080/api/v1
# [ОБЯЗАТЕЛЬНО] Секрет подписи JWT (HS256), минимум 32 байта. Сгенерируйте: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS

# Первый администратор (создаётся при пустой таблице users). Пусто = не создаётся.
BOOTSTRAP_ADMIN_EMAIL=admin@balgyn.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Пароль БД.
POSTGRES_PASSWORD=postgres

# Swagger UI (http://localhost:8080/swagger-ui.html).
SWAGGER_ENABLED=true

# Заполнить каталог тестовыми данными при первом старте (5 групп, 14 коллекций, 16 дизайнов).
# Безопасно: пропускается, если каталог уже наполнен.
APP_SEED_CATALOG=true

# ── MinIO / Storage ──────────────────────────────────────────────────────────
# false = загрузка выключена (локально без MinIO).
STORAGE_ENABLED=false
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_PUBLIC_URL=http://localhost:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET=balgyn-media

# ── CDEK (доставка) ───────────────────────────────────────────────────────────
# Пустые значения = stub/mock-режим. Заполняйте только при интеграции с реальным CDEK.
# CDEK_CLIENT_ID=
# CDEK_CLIENT_SECRET=
# Токен для верификации входящих вебхуков CDEK (X-Authorization header).
# Задаётся в личном кабинете CDEK при регистрации вебхука.
# CDEK_WEBHOOK_TOKEN=

# ── Freedom Pay ───────────────────────────────────────────────────────────────
# Данные из личного кабинета Freedom Pay (https://merchant.freedompay.kz).
# Пустой FREEDOMPAY_MERCHANT_ID = stub-режим: API-вызовов нет, возвращается фиктивный URL.
# Для sandbox-тестирования заполните все поля ниже.
FREEDOMPAY_MERCHANT_ID=YOUR_FREEDOMPAY_MERCHANT_ID
FREEDOMPAY_SECRET_KEY=YOUR_FREEDOMPAY_SECRET_KEY
# Sandbox API (используйте для тестирования):
FREEDOMPAY_API_URL=https://api.freedompay.kz
# URL, на который Freedom Pay отправит результат оплаты (должен быть публично доступен).
# Для локального тестирования используйте ngrok: https://<id>.ngrok.io/api/v1/payments/callback/freedom-pay
FREEDOMPAY_RESULT_URL=https://balgyn.kz/api/v1/payments/callback/freedom-pay
# URL редиректа пользователя после оплаты:
FREEDOMPAY_SUCCESS_URL=http://localhost:5173/payment/success
FREEDOMPAY_FAILURE_URL=http://localhost:5173/payment/failed
# Имя скрипта для MD5-подписи — должно совпадать с последним сегментом FREEDOMPAY_RESULT_URL.
FREEDOMPAY_CALLBACK_SCRIPT_NAME=freedom-pay
# true = sandbox-режим Freedom Pay (pg_testing_mode=1). Обязательно для тестирования.
FREEDOMPAY_TESTING_MODE=true

# ── PayPal ────────────────────────────────────────────────────────────────────
# Данные из PayPal Developer Dashboard (https://developer.paypal.com/dashboard/).
# Пустые PAYPAL_CLIENT_ID/SECRET — приложение стартует, но API вернёт ошибку.
# PAYPAL_MODE: "sandbox" (тест) или "live" (продакшн).
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
# Webhook ID из раздела Webhooks в PayPal Developer Dashboard.
# Требуется для верификации подписи входящих webhook-событий.
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID
