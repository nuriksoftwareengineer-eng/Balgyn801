# ──────────────────────────────────────────────────────────────────────────────
# BALGYN — локальная конфигурация.
# Файл .env в .gitignore и НЕ коммитится.
# ──────────────────────────────────────────────────────────────────────────────
# ── Production domain ─────────────────────────────────────────────────────────
# Required for HTTPS (nginx ssl_certificate path + CORS).
DOMAIN=balgyn.kz
# Email used by Let's Encrypt for certificate expiry notifications.
CERTBOT_EMAIL=admin@balgyn.kz

VITE_API_BASE_URL=http://localhost:8080/api/v1
# [ОБЯЗАТЕЛЬНО] Секрет подписи JWT (HS256), минимум 32 байта. Сгенерируйте: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS

# Первый администратор (создаётся при пустой таблице users). Пусто = не создаётся.
BOOTSTRAP_ADMIN_EMAIL=admin@balgyn.local
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Пароль БД.
POSTGRES_PASSWORD=postgres

# Swagger UI (http://localhost:8080/swagger-ui.html).
SWAGGER_ENABLED=true

# Заполнить каталог тестовыми данными при первом старте (5 групп, 14 коллекций, 16 дизайнов).
# Безопасно: пропускается, если каталог уже наполнен.
APP_SEED_CATALOG=true

# ── MinIO / Storage ──────────────────────────────────────────────────────────
# false = загрузка выключена (локально без MinIO).
STORAGE_ENABLED=false
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_PUBLIC_URL=http://localhost:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET=balgyn-media

# ── CDEK (доставка) ───────────────────────────────────────────────────────────
# api.cdek.ru/v2 (prod), edu sandbox отклоняет боевые ключи с 401.
# ВНИМАНИЕ: заполняйте реальными значениями только в .env / .env.prod (в .gitignore).
# Никогда не коммитьте реальные CDEK-ключи в этот файл.
CDEK_BASE_URL=https://api.cdek.ru/v2
CDEK_CLIENT_ID=REPLACE_WITH_CDEK_CLIENT_ID
CDEK_CLIENT_SECRET=REPLACE_WITH_CDEK_CLIENT_SECRET
# Токен для верификации входящих вебхуков CDEK (X-Authorization header).
# CDEK_WEBHOOK_TOKEN=

# ── Freedom Pay ───────────────────────────────────────────────────────────────
# ВАЖНО: для получения callback FreedomPay нужен публичный URL (ngrok / реальный домен).
# Без FREEDOMPAY_RESULT_URL → stub-режим автоматически подтверждает заказы локально.
# Заполняйте реальными значениями только в .env / .env.prod (в .gitignore).
FREEDOMPAY_MERCHANT_ID=REPLACE_WITH_FREEDOMPAY_MERCHANT_ID
FREEDOMPAY_SECRET_KEY=REPLACE_WITH_FREEDOMPAY_SECRET_KEY
FREEDOMPAY_API_URL=https://api.freedompay.kz
# Публичный URL для callback от Freedom Pay. Используйте ngrok для локального тестирования:
# npx ngrok http 8080
# Затем: FREEDOMPAY_RESULT_URL=https://<id>.ngrok.io/api/v1/payments/callback/freedom-pay
FREEDOMPAY_RESULT_URL=
FREEDOMPAY_CALLBACK_SCRIPT_NAME=freedom-pay
FREEDOMPAY_TESTING_MODE=true

# ── PayPal ────────────────────────────────────────────────────────────────────
# "sandbox" для тестовых ключей с developer.paypal.com/dashboard (sandbox-приложение),
# "live" для боевых ключей. Заполняйте реальными значениями только в .env / .env.prod.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=REPLACE_WITH_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_PAYPAL_CLIENT_SECRET
PAYPAL_WEBHOOK_ID=REPLACE_WITH_PAYPAL_WEBHOOK_ID

# ── Email уведомления (регистрация, заказы, оплата) ────────────────────────────
# false = email отключены (по умолчанию). Включите и заполните SMTP, чтобы письма реально уходили.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# Для Gmail используйте App Password (не обычный пароль аккаунта).
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@balgyn.kz

# ── Telegram (Mini App вход + уведомления) ─────────────────────────────────────
# false = Telegram отключён (по умолчанию).
TELEGRAM_ENABLED=true
# Токен ОСНОВНОГО бота (Mini App) от @BotFather: вход через Telegram, кнопка меню,
# сообщения покупателям о статусе заказа. Заполняйте реальным значением только в .env / .env.prod.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
# Chat ID для админ-алертов (узнать через @userinfobot).
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID
# Отдельный бот для админ-алертов (опционально). Пусто = алерты идут через основного
# бота (TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID). Покупателям всегда пишет основной бот.
# TELEGRAM_ADMIN_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
