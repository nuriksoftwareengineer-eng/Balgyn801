{
    email {$CERTBOT_EMAIL}
}

{$DOMAIN} {
    # Compress text assets (JS/CSS/HTML/JSON/SVG). Audit proved responses were served
    # uncompressed (Content-Length == decoded size); this cuts JS/CSS transfer ~70%.
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # No X-Frame-Options here: it has no multi-origin syntax, and CSP frame-ancestors
        # (below) is what actually needs to allow Telegram's webview to iframe the site —
        # keeping a conflicting SAMEORIGIN alongside would be redundant, not protective.
        # frame-ancestors allows Telegram's own webview origins to iframe the Mini App.
        # (@telegram-apps/sdk talks to the native app over its own bridge, not the official
        # telegram-web-app.js script, so script-src needs no telegram.org allowance.)
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors https://web.telegram.org https://telegram.org;"
    }

    request_body {
        max_size 20MB
    }

    handle /api/* {
        reverse_proxy app:8080
    }
    # handle_path (not handle) strips the /media prefix before proxying. MinIO's S3 API
    # expects the request path to be exactly /{bucket}/{key} -- forwarding /media/{bucket}/{key}
    # unchanged (as plain `handle` does) makes MinIO read "media" itself as the bucket name,
    # which doesn't exist, so every public image URL 403'd even though the object was
    # uploaded fine (the app talks to MinIO directly over the Docker network, bypassing
    # this route entirely, so uploads always looked like they succeeded).
    handle_path /media/* {
        reverse_proxy minio:9000
    }
    handle {
        reverse_proxy frontend:80
    }
}

